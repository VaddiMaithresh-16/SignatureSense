# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/SignatureVerification

# Server Configuration
PORT=5051
NODE_ENV=development

# Flask API (for image comparison)
FLASK_API_URL=http://localhost:7777

# Signature Verification Threshold (0.0 to 1.0)
# Higher = stricter matching, Lower = more lenient
# Default: 0.99995
SIMILARITY_THRESHOLD=0.99995
